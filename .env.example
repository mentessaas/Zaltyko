# ===========================================
# ZALTYYKO - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Alias legacy aceptado solo como fallback; preferir NEXT_PUBLIC_APP_URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=development
INTERNAL_AUTH_SECRET=generate_a_distinct_internal_secret

# Supabase
# Get these from: https://app.supabase.com/project/_/settings/api
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@HOST:PORT/postgres?sslmode=require
DATABASE_URL_POOL=postgresql://postgres:YOUR_PASSWORD@HOST:PORT/postgres?pgbouncer=true&sslmode=require
DATABASE_URL_DIRECT=postgresql://postgres:YOUR_PASSWORD@HOST:PORT/postgres
# Presupuesto por instancia serverless. Ajustar solo con métricas del pooler.
DATABASE_POOL_MAX=5
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# Vercel KV / Upstash (required in production for global rate limiting)
KV_REST_API_URL=https://your-kv-endpoint.example
KV_REST_API_TOKEN=your_kv_rest_api_token

# Stripe (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Clave publicable (cliente) para Stripe.js / Elements en el portal de familias
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook de cuentas conectadas (Stripe Connect). Secret de firma propio,
# distinto de STRIPE_WEBHOOK_SECRET. Endpoint: /api/stripe/connect/webhook
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...

# Brevo Email (get from https://app.brevo.com/settings/keys/smtp)
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=admin@yourdomain.com
BREVO_SENDER_NAME=YourAppName
BREVO_REPLY_TO=soporte@yourdomain.com

# Solo para el webhook inbound legado /api/mailgun; no es proveedor de envío.
MAILGUN_SIGNING_KEY=your_mailgun_signing_key

# Web Push (VAPID keys - generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your_vapid_public_key
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@yourdomain.com

# Cron secret (for securing cron endpoints)
CRON_SECRET=your_cron_secret_here

# Supabase CA bundle (needed for db:migrate against Supabase pooler in dev).
# Public cert at ./certs/supabase-root-ca.crt
NODE_EXTRA_CA_CERTS=./certs/supabase-root-ca.crt

# Playwright E2E auth
# Use existing, isolated test accounts only. Role-specific login runs only when
# both its email and password are configured; no user is created by default.
E2E_AUTH_EMAIL=e2e-owner@zaltyko.test
E2E_AUTH_PASSWORD=change-me
E2E_ACADEMY_ID=00000000-0000-0000-0000-000000000000
E2E_ALLOW_PROVISIONING=false
E2E_STORAGE_STATE=.auth/user.json
E2E_OWNER_STORAGE_STATE=.auth/user.json
E2E_COACH_EMAIL=e2e-coach@zaltyko.test
E2E_COACH_PASSWORD=
E2E_COACH_STORAGE_STATE=.auth/coach.json
E2E_SUPER_ADMIN_EMAIL=e2e-super-admin@zaltyko.test
E2E_SUPER_ADMIN_PASSWORD=
E2E_SUPER_ADMIN_STORAGE_STATE=.auth/super-admin.json

# Optional runtime integrations and local-only flags
# Leave disabled/empty unless the feature is explicitly enabled.
ENABLE_DEV_FEATURES=false
NEXT_PUBLIC_DEV_FEATURES=false
NEXT_PUBLIC_ENABLE_DEV_FEATURES=false
NEXT_PUBLIC_ENABLE_DEV_SESSION=false
NEXT_PUBLIC_DISABLE_ANALYTICS=false
NEXT_PUBLIC_USE_MOCK_AUTH=false
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=
MINIMAX_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
MOCK_DEV_ACADEMY_ID=
MOCK_DEV_PROFILE_ID=
MOCK_DEV_TENANT_ID=
MOCK_DEV_USER_ID=
# Next.js internal build/runtime markers (do not set manually)
NEXT_PHASE=
NEXT_RUNTIME=
